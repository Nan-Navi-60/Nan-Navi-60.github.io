.idea/
.vscode/
*.swp
*.swo

# OS System Files (Windows, Mac 불필요한 썸네일 파일 등)
Thumbs.db
ehthumbs.db
Desktop.ini
.DS_Store
.AppleDouble
.LSOverride

# npm (가끔 생기는 로그)
package-lock.json.lock

# 무시해도 괜찮은 파일 리스트
temp/