# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (보안상 매우 중요 - API 키 노출 방지)
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env*.local

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# --------------------------------------------------
# 👇 여기서부터 추가된 항목입니다 (Windows & IDE)
# --------------------------------------------------

# IDE (VS Code, JetBrains 등 에디터 설정 파일 무시)
.idea/
.vscode/
*.swp
*.swo

# OS System Files (Windows, Mac 불필요한 썸네일 파일 등)
Thumbs.db
ehthumbs.db
Desktop.ini
.DS_Store
.AppleDouble
.LSOverride

# npm (가끔 생기는 로그)
package-lock.json.lock

# 무시해도 괜찮은 파일 리스트
temp/

# 로그 데이터
*.log

# 대화 관련 기록 및 수정 기록 (docs 폴더 내 원본/대화 내역)
docs/conversation*.md
docs/work_progress*.md

# 기타 참고용 원본 문서 리스트가 커밋되지 않길 원하신다면 아래 부분 주석을 해제하세요
# docs/*_detail.md
# docs/project_content_writing_manual.md

# 백업 및 임시 데이터
*.bak
*.backup
*.tmp
*.temp
*~

